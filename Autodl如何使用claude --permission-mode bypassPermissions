#!/bin/bash

# ================= 配置区 =================
# 你可以把这里改成你想要的任何名字
NEW_USER="devuser"
# ==========================================

echo "🚀 开始打造 Root 的完美克隆体: $NEW_USER"

# 1. 安装 sudo (如果尚未安装)
apt-get update && apt-get install -y sudo

# 2. 创建用户并指定默认 Shell 为 bash
# -m 会自动创建 /home/devuser 目录
useradd -m -s /bin/bash $NEW_USER 

# 3. 赋予最高级别的免密 sudo 权限
echo "🔑 注入免密超级管理员权限..."
echo "$NEW_USER ALL=(ALL:ALL) NOPASSWD: ALL" > /etc/sudoers.d/$NEW_USER
chmod 0440 /etc/sudoers.d/$NEW_USER

# 4. 像素级继承 Root 的环境变量 (核心操作)
echo "🧬 正在克隆 Root 的环境变量与配置..."
cp /root/.bashrc /home/$NEW_USER/.bashrc
[ -f /root/.profile ] && cp /root/.profile /home/$NEW_USER/.profile

# 5. 智能修复环境变量中的硬编码路径 (防报错关键)
# 把 root 配置里写死的 /root 路径，智能替换为新用户的家目录
sed -i "s|/root|/home/$NEW_USER|g" /home/$NEW_USER/.bashrc
[ -f /root/.profile ] && sed -i "s|/root|/home/$NEW_USER|g" /home/$NEW_USER/.profile

# 6. 配置 sudo 的变量继承保护
# 默认情况下 sudo 会重置环境变量。这行配置可以让 devuser 在执行 sudo 时，保留需要的系统变量
echo "Defaults:$NEW_USER env_keep += \"PATH PYTHONPATH HTTP_PROXY HTTPS_PROXY http_proxy https_proxy\"" >> /etc/sudoers.d/$NEW_USER

# 7. 修正所有权，把复制过来的配置文件完全交给新用户
chown -R $NEW_USER:$NEW_USER /home/$NEW_USER/

echo "✅ 克隆完成！一个拥有 Root 全部底牌的普通用户已上线。"
echo "👉 请输入命令切换身份: su - $NEW_USER"

